# -------------------- IMPORT SECTION --------------------

# Importing required libraries
import tkinter as tk                  # Used to create GUI
from tkinter import messagebox        # Used to show popup messages
import os                             # Added (not used, but imported as requested)
import sys                            # Added (not used, but imported as requested)
import time                           # Added (not used, but imported as requested)


# -------------------- DATA STRUCTURE --------------------

# equipment_list is a LIST that stores all available equipment items
equipment_list = [
    "Laptop 1", "Laptop 2",
    "Projector A", "Projector B",
    "Tablet 1", "Tablet 2"
]

# bookings is a LIST that will store all booking records as dictionaries
bookings = []

# booking_id_counter is used to generate unique ID for each booking
booking_id_counter = 1


# -------------------- MAIN WINDOW --------------------

# Creating the main window
root = tk.Tk()

# Setting window title
root.title("Student Equipment Booking System")

# Setting window size
root.geometry("1000x600")

# Setting background color
root.configure(bg="#f2e4b3")


# -------------------- FUNCTIONS (LOGIC UNCHANGED) --------------------

# Function to add new equipment into equipment_list
def add_equipment():
    name = entry_equipment.get().strip()

    if name:
        if name not in equipment_list:
            equipment_list.append(name)
            messagebox.showinfo("Success", "Equipment added successfully.")
        else:
            messagebox.showwarning("Warning", "Equipment already exists.")

    entry_equipment.delete(0, tk.END)


# Function to record a new booking
def record_booking():
    global booking_id_counter

    student = entry_student.get().strip()
    equipment = entry_booking_equipment.get().strip()
    date = entry_date.get().strip()

    # Check if equipment exists
    if equipment not in equipment_list:
        messagebox.showwarning("Warning", "Equipment does not exist.")
        return

    # Prevent double booking on same date
    for booking in bookings:
        if booking["equipment"] == equipment and booking["date"] == date:
            messagebox.showwarning("Warning", "Equipment already booked for this date.")
            return

    # Create booking dictionary
    new_booking = {
        "id": booking_id_counter,
        "student": student,
        "equipment": equipment,
        "date": date
    }

    # Add booking to bookings list
    bookings.append(new_booking)

    # Increase ID counter
    booking_id_counter += 1

    messagebox.showinfo("Success", "Booking recorded successfully.")


# Function to display all equipment
def view_equipment():
    output.delete("1.0", tk.END)

    if not equipment_list:
        output.insert(tk.END, "No equipment available.\n")
    else:
        for item in equipment_list:
            output.insert(tk.END, f"{item}\n")


# Function to display all bookings
def view_bookings():
    output.delete("1.0", tk.END)

    if not bookings:
        output.insert(tk.END, "No bookings found.\n")
    else:
        for booking in bookings:
            output.insert(
                tk.END,
                f"ID: {booking['id']} | Student: {booking['student']} | "
                f"Equipment: {booking['equipment']} | Date: {booking['date']}\n"
            )


# Function to search bookings by student name
def search_by_student():
    name = entry_search_student.get().strip()
    output.delete("1.0", tk.END)

    found = False

    for booking in bookings:
        if booking["student"] == name:
            output.insert(
                tk.END,
                f"ID: {booking['id']} | Equipment: {booking['equipment']} | Date: {booking['date']}\n"
            )
            found = True

    if not found:
        output.insert(tk.END, "No bookings found.\n")


# Function to cancel booking using Booking ID
def cancel_booking():
    try:
        cancel_id = int(entry_cancel_id.get().strip())
    except ValueError:
        messagebox.showwarning("Warning", "Invalid ID.")
        return

    for booking in bookings:
        if booking["id"] == cancel_id:
            bookings.remove(booking)
            messagebox.showinfo("Success", "Booking cancelled successfully.")
            return

    messagebox.showwarning("Warning", "Booking ID not found.")


# -------------------- NEW FEATURE --------------------
# Function to remove equipment item from equipment_list

def remove_equipment():
    name = entry_remove_equipment.get().strip()

    if name in equipment_list:
        equipment_list.remove(name)
        messagebox.showinfo("Success", "Equipment removed successfully.")
    else:
        messagebox.showwarning("Warning", "Equipment not found.")

    entry_remove_equipment.delete(0, tk.END)


# -------------------- FRAME STRUCTURE --------------------

# Title Frame
frame_title = tk.Frame(root, bg="#f4f6f8")
frame_title.pack(pady=10)

tk.Label(frame_title,
         text="Student Equipment Booking System",
         font=("Arial", 18, "bold"),
         bg="#f4f6f8",
         fg="#2c3e50").pack()


# -------------------- INPUT FRAME --------------------

frame_input = tk.Frame(root, bg="#f4f6f8")
frame_input.pack(pady=10)

# Equipment Add Section
tk.Label(frame_input, text="Equipment Name:", bg="#f4f6f8").grid(row=0, column=0, padx=5, pady=5, sticky="e")
